ADMIN_PASSWORD=change-me-to-a-strong-password

# Public site URL (canonical, sitemap, structured data). Use shines.be now; switch to shines.com when live.
NEXT_PUBLIC_SITE_URL=https://shines.be

# Online booking (on by default; set false only to hide booking temporarily)
# IMPORTANT: Vercel has a read-only filesystem — live bookings need a database (see docs/LAUNCH.md).
# NEXT_PUBLIC_BOOKING_ENABLED=false

# Stripe: return shipping only (Checkout + webhook)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Neon Postgres (Vercel Marketplace → Storage → Neon). Required for live bookings on Vercel.
# Vercel sets POSTGRES_URL; DATABASE_URL also works.
# POSTGRES_URL=
# DATABASE_URL=

# Resend: transactional mail-in emails (arrived, ready, return shipped)
RESEND_API_KEY=
RESEND_FROM=SHINES <info@shines.be>

# Google Search Console domain verification (meta tag content value only)
# GOOGLE_SITE_VERIFICATION=your-verification-code

# Public contact overrides (optional — set in Vercel when workshop address is confirmed)
# SITE_EMAIL=info@shines.be
# CONTACT_STREET=Industrieweg 12
# CONTACT_POSTAL_CODE=8200
# CONTACT_CITY=Brugge
# CONTACT_PHONE=+32 ...
# MAPS_LINK=https://maps.app.goo.gl/...
# MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# Mobile travel pricing: your garage address or coordinates
# Example address: Industrieweg 12, 8200 Brugge, Belgium
WORKSHOP_ADDRESS=Brugge, Belgium
# Or set exact coordinates instead of geocoding:
# WORKSHOP_LAT=51.2085526
# WORKSHOP_LON=3.2267720
