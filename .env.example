ADMIN_PASSWORD=change-me-to-a-strong-password

# Public site URL (booking links in emails)
NEXT_PUBLIC_SITE_URL=https://shines.be

# Online booking (on by default; set false only to hide booking temporarily)
# NEXT_PUBLIC_BOOKING_ENABLED=false

# Stripe — return shipping only (Checkout + webhook)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — transactional mail-in emails (arrived, ready, return shipped)
RESEND_API_KEY=
RESEND_FROM=SHINES <hello@shines.be>

# Mobile travel pricing — your garage address or coordinates
# Example address: Industrieweg 12, 8200 Brugge, Belgium
WORKSHOP_ADDRESS=Brugge, Belgium
# Or set exact coordinates instead of geocoding:
# WORKSHOP_LAT=51.2085526
# WORKSHOP_LON=3.2267720
