{
  "ref": {
    "color": {
      "brand": { "$type": "color", "$value": "#070322" },
      "canvasDark": { "$type": "color", "$value": "#030406" },
      "actionPrimary": { "$type": "color", "$value": "#0076DF" },
      "actionDanger": { "$type": "color", "$value": "#E30A2B" },
      "neutral0": { "$type": "color", "$value": "#ffffff" },
      "neutral100": { "$type": "color", "$value": "#070322" }
    },
    "space": {
      "4": { "$type": "dimension", "$value": { "value": 4, "unit": "px" } },
      "8": { "$type": "dimension", "$value": { "value": 8, "unit": "px" } },
      "12": { "$type": "dimension", "$value": { "value": 12, "unit": "px" } },
      "16": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
      "24": { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
      "32": { "$type": "dimension", "$value": { "value": 32, "unit": "px" } },
      "48": { "$type": "dimension", "$value": { "value": 48, "unit": "px" } },
      "64": { "$type": "dimension", "$value": { "value": 64, "unit": "px" } }
    },
    "radius": {
      "pill": { "$type": "dimension", "$value": { "value": 9999, "unit": "px" } },
      "md": { "$type": "dimension", "$value": { "value": 8, "unit": "px" } }
    }
  },
  "sys": {
    "color": {
      "canvas": { "$type": "color", "$value": "{ref.color.brand}" },
      "surface": { "$type": "color", "$value": "{ref.color.neutral0}" },
      "text": {
        "primary": { "$type": "color", "$value": "{ref.color.neutral100}" },
        "onDark": { "$type": "color", "$value": "{ref.color.neutral0}" }
      },
      "action": {
        "primary": { "$type": "color", "$value": "{ref.color.actionPrimary}" },
        "danger": { "$type": "color", "$value": "{ref.color.actionDanger}" }
      }
    }
  }
}
